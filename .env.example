# === .env.example for WanderFuel simulation ===
# Copy to .env and edit if you need runtime overrides.
# If .env is missing, config.yaml fallbacks are used — nothing breaks.

# --- consumed by: simulation/gen/generator.py ---------------------------
#     (also read by docker-compose via ${VAR} substitution if used)
POSTGRES_APP_HOST=localhost
POSTGRES_APP_PORT=5432
POSTGRES_APP_USER=app_user
POSTGRES_APP_PASS=app_pass
POSTGRES_APP_DB=app_oltp

# --- consumed by: simulation/gen/generator.py ---------------------------
CRM_SFTP_HOST=localhost
CRM_SFTP_PORT=2222
CRM_SFTP_USER=crm_vendor
CRM_SFTP_PASS=crm_pass
CRM_SFTP_PATH=tickets

# --- consumed by: simulation/sources/vendor_api/main.py (inside container)
VENDOR_DB_PATH=./store/vendor.db

# --- consumed by: MinIO (docker-compose.pipeline.yml) -----------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# --- consumed by: dagster_pipeline assets -----------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=wanderfuel-bronze
# --- consumed by: ClickHouse (docker-compose.pipeline.yml) ------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=wanderfuel
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# --- consumed by: dagster_pipeline/dagster_home/dagster.yaml ---------------
POSTGRES_DAGSTER_DB=dagster_metadata
